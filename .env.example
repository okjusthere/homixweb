# Copy to .env.local and fill in. .env.local is gitignored.

# --- Listings data source ---------------------------------------------------
# "mock"   -> bundled sample data, no credentials (default, for dev/design)
# "onekey" -> live OneKey MLS / RESO Web API feed (requires the credentials below)
LISTINGS_PROVIDER=mock

# --- OneKey MLS (only when LISTINGS_PROVIDER=onekey) -------------------------
# Requires: OneKey MLS Participant status (Broker of Record) + a signed IDX
# Data License Agreement + your feed/domain registered with OneKey. You then
# receive a RESO Web API base URL and an OAuth2/API bearer token.
ONEKEY_API_BASE=
ONEKEY_TOKEN=
# Optional — your ListOfficeMlsId, used to feature Homix's own listings:
ONEKEY_OFFICE_ID=

# --- Agent self-edit (Supabase) ---------------------------------------------
# When set, advisor profiles are read from Supabase and advisors can self-edit
# via their /edit/<token> link. Leave blank to keep the static roster.
# From Supabase: Project Settings -> API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Password for the /admin dashboard login.
ADMIN_PASSWORD=

# --- Website inquiries ------------------------------------------------------
# Contact forms write to Supabase public.inquiries and send an email through
# Resend. Verify the sending domain in Resend before launch.
RESEND_API_KEY=
INQUIRY_TO_EMAIL=homix@homixny.com
INQUIRY_FROM_EMAIL="Homix Website <inquiries@homixny.com>"
# Optional comma-separated internal copies.
INQUIRY_BCC_EMAIL=

# --- Scheduled listing refresh (optional, Vercel) ---------------------------
# Leave blank until the MLS/listing specialist finalizes refresh operations.
CRON_SECRET=
DEPLOY_HOOK_URL=

# --- Embeds (/offer + /buyercoach) ------------------------------------------
# Public (non-secret) embed targets. Defaults are hardcoded in src/lib/embeds.ts;
# set these only to override without a code change (NEXT_PUBLIC_* need a redeploy).
# Tally form id from tally.so/r/<ID>:
NEXT_PUBLIC_TALLY_OFFER_ID=
# Optional separate Chinese-language Tally form (falls back to the one above):
NEXT_PUBLIC_TALLY_OFFER_ID_ZH=
# Full FastGPT share/iframe URL for the buyer coach:
NEXT_PUBLIC_BUYERCOACH_URL=

# --- Site ------------------------------------------------------------------
# Public origin, used for canonical URLs, sitemap.xml and Open Graph tags.
NEXT_PUBLIC_SITE_URL=https://www.homixny.com
